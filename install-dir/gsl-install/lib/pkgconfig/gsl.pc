prefix=D:/projects/wu-env-qt6.11/install-dir/gsl-install
exec_prefix=D:/projects/wu-env-qt6.11/install-dir/gsl-install
libdir=${prefix}/lib
includedir=${prefix}/include
GSL_CBLAS_LIB=-lgslcblas

Name: GSL
Description: GNU Scientific Library
Version: 2.7
Libs: -L${libdir} -lgsl ${GSL_CBLAS_LIB} -lm -lm
Cflags: -I${includedir}
