prefix=D:/projects/wu-env-qt6.11/install-dir/quazip-install
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include

Name: QuaZip-Qt6
Description: Minizip wrapper library for Qt 6.x
Version: 1.5
Libs: -L${libdir} -lquazip1-qt6
Cflags: -I${includedir}/QuaZip-Qt6-1.5 -I${includedir}/QuaZip-Qt6-1.5/quazip
Requires: zlib, Qt6Core
